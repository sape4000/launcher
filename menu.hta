<html>
<head>
    <title>Asterios Manager Pro: Chaotic Chronicle</title>
    <meta http-equiv="cache-control" content="no-cache">
    <meta http-equiv="expires" content="0">
    <meta http-equiv="Content-Type" content="text/html; charset=windows-1251">
    <hta:application id="oApp" scroll="no" windowstate="normal" selection="no" contextmenu="no">
      <style>
        body { 
            font-family: "Segoe UI", "Tahoma", sans-serif; 
            margin: 0; padding: 0; overflow: hidden;
            background-color: #0b1622; 
            filter: progid:DXImageTransform.Microsoft.gradient(startColorstr='#162a3e', endColorstr='#050a12', GradientType=0);
            color: #d1d1d1;
        }
        
        .tabs-table { width: 100%; border-collapse: collapse; table-layout: fixed; background: rgba(0,0,0,0.7); border-bottom: 1px solid #3d4a5d; }
        .tab { padding: 12px; text-align: center; font-weight: bold; cursor: pointer; color: #8a9299; text-transform: uppercase; font-size: 11px; letter-spacing: 1px; }
        .tab-active { background: rgba(184, 158, 102, 0.15); color: #e5c38c; border-bottom: 2px solid #b89e66; text-shadow: 0 0 8px #b89e66; }
        
        .main-container { padding: 0; height: auto; overflow-y: auto; overflow-x: hidden; background: transparent; }

        .settings-width { width: 400px; position: relative; margin: 20px auto 0 auto; padding: 15px; left: 50%; margin-left: -200px; box-sizing: border-box; }
        
        .group-head { 
            background: #152231;
            color: #e5c38c; padding: 10px 15px; cursor: pointer; font-weight: bold; border-top: 1px solid #3d4a5d; border-bottom: 1px solid #000;
            font-size: 13px; width: 100%; box-sizing: border-box; text-shadow: 1px 1px 2px #000;
        }
        .group-content { display: none; padding: 8px; background: rgba(0, 0, 0, 0.4); border-bottom: 1px solid #1a2432; width: 100%; box-sizing: border-box; }
        
        .key-table { width: 100%; border-collapse: separate; border-spacing: 6px; table-layout: fixed; }
        .btn-acc { 
            width: 100%; height: 38px; padding: 0 5px; cursor: pointer; text-align: center;
            background: #1c2a3d; border: 1px solid #3d4a5d; border-radius: 2px;
            font-weight: bold; color: #fff; font-size: 15px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; line-height: 36px;
        }
        .btn-acc:hover { background: #2a3d52; border-color: #b89e66; color: #e5c38c; }
        
        .edit-container-tab { background: transparent; min-height: 100%; display: flex; flex-direction: column; }
        
        /* Родные стабильные 550px, при которых скроллинг идеально работал */
                /* Высота автоматически подстраивается под экран, сохраняя скролл и черный цвет полосы */
        ..edit-scroll-box { height: auto; overflow-y: auto; background: rgba(0,0,0,0.3); padding: 10px; border-bottom: 1px solid #3d4a5d; }
        .edit-table { width: 100%; border-collapse: collapse; font-size: 12px; color: #faebd7; } 
        .edit-table th { background: #1a2b3c; padding: 10px; border: 1px solid #3d4a5d; color: #e5c38c; text-transform: uppercase; font-size: 11px; }
        .edit-table td { padding: 6px; border: 1px solid #222; background: rgba(20,30,45,0.6); color: #fff; } 
        
        .clickable-name { 
            color: #ffffff; 
            cursor: pointer; 
            text-decoration: none; 
            font-weight: bold; 
            display: block; 
            text-align: left; 
            padding-left: 5px;
            text-shadow: 1px 1px 1px #000;
        }
        .clickable-name:hover { color: #e5c38c; text-decoration: underline; }
        
        select { background: #0a111a; color: #fff; border: 1px solid #4a5a6d; padding: 3px; font-size: 12px; width: 100%; }
        option { background: #0a111a; color: #fff; }

        .btn-arr { width: 24px; height: 24px; cursor: pointer; background: #1a2b3c; border: 1px solid #4a5a6d; color: #e5c38c; font-weight: bold; }
        .btn-del-row { width: 24px; height: 24px; cursor: pointer; color: #ff4757; background: #1a2b3c; border: 1px solid #4a5a6d; font-weight: bold; }
        
        .config-box { background: rgba(10,20,30,0.7); padding: 20px; border: 1px solid #3d4a5d; border-radius: 4px; }
        .label-text { font-weight: bold; font-size: 12px; color: #e5c38c; margin-bottom: 5px; margin-top: 10px; }
        .input-path { width: 100%; height: 30px; border: 1px solid #3d4a5d; background: #050a12; color: #aaa; font-size: 12px; padding: 0 8px; }
        .input-field { width: 100%; padding: 8px; border: 1px solid #3d4a5d; background: #050a12; color: #fff; font-size: 12px; }
        
        .btn-save { width: 100%; padding: 14px; background: #b89e66; color: #111; border: none; font-weight: bold; cursor: pointer; text-transform: uppercase; font-size: 12px; }
        .btn-exit { width: 100%; padding: 10px; border: 1px solid #7f232b; color: #ff4757; background: rgba(40,10,15,0.6); font-weight: bold; cursor: pointer; text-transform: uppercase; }
    </style>

    <script language="VBScript">
        Set objShell = CreateObject("WScript.Shell")
        Set fso = CreateObject("Scripting.FileSystemObject")
        Dim kFile, cFile, globalOpenGroups, globalGroupOrder, globalEditIdx

         Sub Window_OnLoad
            Dim currentHeight
            currentHeight = document.body.clientHeight
            If currentHeight > 700 Then
                document.getElementById("c3").style.height = (currentHeight - 50) & "px"
                document.getElementById("edit_list").style.height = (currentHeight - 160) & "px"
            Else
                document.getElementById("c3").style.height = "520px"
                document.getElementById("edit_list").style.height = "450px"
            End If
            p = fso.GetParentFolderName(Replace(oApp.commandLine, Chr(34), ""))
            kFile = p & "\keys.txt" : cFile = p & "\config.ini"
            If Not fso.FileExists(kFile) Then fso.CreateTextFile(kFile).Close
            If Not fso.FileExists(cFile) Then
                Set f = fso.CreateTextFile(cFile)
                f.WriteLine "C:\AsteriosGame.ini" : f.WriteLine "2" : f.WriteLine "" : f.WriteLine "Разное" : f.Close
            End If
            LoadData
        End Sub


        Sub ShowTab(num)
            For i = 1 To 3
                document.getElementById("t" & i).className = "tab"
                document.getElementById("c" & i).style.display = "none"
            Next
            document.getElementById("t" & num).className = "tab tab-active"
            document.getElementById("c" & num).style.display = "block"
  	 currentHeight = document.body.clientHeight
            If currentHeight > 700 Then
                document.getElementById("c3").style.height = (currentHeight - 50) & "px"
                document.getElementById("edit_list").style.height = (currentHeight - 160) & "px"
            Else
                 document.getElementById("c3").style.height = "520px"
                document.getElementById("edit_list").style.height = "450px"
            End If
        End Sub

        Sub ToggleGroup(id, gName)
            Set content = document.getElementById("g_" & id)
            Set head = document.getElementById("h_" & id)
            If content.style.display = "block" Then
                content.style.display = "none" : head.innerText = "[+] " & gName
                globalOpenGroups = Replace(globalOpenGroups, "{" & gName & "}", "")
            Else
                content.style.display = "block" : head.innerText = "[-] " & gName
                If InStr(globalOpenGroups, "{" & gName & "}") = 0 Then globalOpenGroups = globalOpenGroups & "{" & gName & "}"
            End If
            SaveSettings
        End Sub

        Sub SaveSettings()
            On Error Resume Next
            Set f = fso.OpenTextFile(cFile, 2)
            f.WriteLine document.getElementById("pathInput").value
            f.WriteLine document.getElementById("selCols").value
            f.WriteLine globalOpenGroups
            f.WriteLine globalGroupOrder
            f.Close
        End Sub

        Sub LoadData()
		On Error GoTo 0
            On Error Resume Next
            Set f = fso.OpenTextFile(cFile, 1)
            pGame = f.ReadLine : colsCount = CInt(f.ReadLine)
            globalOpenGroups = "" : If Not f.AtEndOfStream Then globalOpenGroups = f.ReadLine
            globalGroupOrder = "" : If Not f.AtEndOfStream Then globalGroupOrder = f.ReadLine
            f.Close
            
            document.getElementById("pathInput").value = pGame
            document.getElementById("selCols").value = colsCount
            window.resizeTo 420 + ((colsCount - 1) * 140), 750

            Set f = fso.OpenTextFile(kFile, 1)
            allData = "" : If Not f.AtEndOfStream Then allData = f.ReadAll : f.Close
            rawLines = Split(allData, vbCrLf)

            Set groups = CreateObject("Scripting.Dictionary")
            Set groups("Разное") = CreateObject("System.Collections.ArrayList")
            For i = 0 To UBound(rawLines)
                If InStr(rawLines(i), "|") > 0 Then
                    p = Split(rawLines(i), "|")
                    cat = Trim(p(2)) : If cat = "" Then cat = "Разное"
                    If Not groups.Exists(cat) Then Set groups(cat) = CreateObject("System.Collections.ArrayList")
                    groups(cat).Add p(1) & "||" & p(0) & "||" & i
                End If
            Next

            tmpOrder = globalGroupOrder
            If InStr("," & tmpOrder & ",", ",Разное,") = 0 Then
                If tmpOrder = "" Then tmpOrder = "Разное" Else tmpOrder = "Разное," & tmpOrder
            End If
            For Each g In groups.Keys
                If InStr("," & tmpOrder & ",", "," & g & ",") = 0 Then tmpOrder = tmpOrder & "," & g
            Next
            globalGroupOrder = tmpOrder
            finalOrder = Split(globalGroupOrder, ",")

            gn = 0 : htmlAcc = ""
            For Each k In finalOrder
                If groups.Exists(k) Then
                    If Not (k = "Разное" And groups(k).Count = 0) Then
                        gn = gn + 1 : rHtml = "<tr>" : cur = 0
                        disp = "none" : pref = "[+] "
                        If InStr(globalOpenGroups, "{" & k & "}") > 0 Then disp = "block" : pref = "[-] "
                        For Each rowVal In groups(k)
                            parts = Split(rowVal, "||")
                            If cur >= colsCount Then rHtml = rHtml & "</tr><tr>" : cur = 0
                            rHtml = rHtml & "<td class='key-td'><button class='btn-acc' onclick=""VBScript:LaunchGame '" & parts(1) & "', " & CInt(parts(2)) & """>" & parts(0) & "</button></td>"
                            cur = cur + 1
                        Next
                        Do While cur > 0 And cur < colsCount
                            rHtml = rHtml & "<td class='key-td'>&nbsp;</td>" : cur = cur + 1
                        Loop
                        htmlAcc = htmlAcc & "<div class='group-head' id='h_" & gn & "' onclick=""VBScript:ToggleGroup " & gn & ", '" & k & "' "">" & pref & k & "</div>"
                        htmlAcc = htmlAcc & "<div class='group-content' id='g_" & gn & "' style='display:" & disp & "'><table class='key-table'>" & rHtml & "</tr></table></div>"
                    End If
                End If
            Next
            document.getElementById("acc_list").innerHTML = htmlAcc

                 eHtml = "<div class='label-text'>Персонажи:</div><table class='edit-table'><tr><th width='95'>Группа</th><th width='40'>Сорт</th><th>Настройки персонажа</th><th width='25'>X</th></tr>"
            For i = 0 To UBound(rawLines)
                If InStr(rawLines(i), "|") > 0 Then
                    p = Split(rawLines(i), "|")
                    thisCat = Trim(p(2)) : If thisCat = "" Then thisCat = "Разное"
                    wW = "1024" : wH = "768" : wX = "0" : wY = "0" : useOpt = "1"
                    If UBound(p) >= 6 Then
                        wW = p(3) : wH = p(4) : wX = p(5) : wY = p(6)
                    End If
                    If UBound(p) >= 7 Then useOpt = Trim(p(7))
                    chk = "" : If useOpt = "1" Or useOpt = "" Then chk = " checked"

                    eHtml = eHtml & "<tr><td><select onchange=""VBScript:ChangeRowGrp " & i & ", window.event.srcElement.value"">"
                    For Each cName In finalOrder
                        sD = "" : If cName = thisCat Then sD = " selected"
                        eHtml = eHtml & "<option value='" & cName & "'" & sD & ">" & cName & "</option>"
                    Next
                    eHtml = eHtml & "</select></td><td><button class='btn-arr' style='width:16px;height:18px;font-size:9px;padding:0;' onclick=""VBScript:MoveRow " & i & ",-1"">^</button><button class='btn-arr' style='width:16px;height:18px;font-size:9px;padding:0;' onclick=""VBScript:MoveRow " & i & ",1"">v</button></td>"
                    
                    eHtml = eHtml & "<td><div style='display:flex; align-items:center; width:100%;'>"
                    eHtml = eHtml & "<div style='flex-grow:1;'></div>"
                    eHtml = eHtml & "<span style='font-size:10px; color:#e5c38c;'>Nm:</span><input type='text' value=""" & p(1) & """ style='width:55px; padding:1px; border:1px solid #3d4a5d; background:#050a12; color:#fff; font-size:11px;' onchange=""VBScript:InlineSave " & i & ", 1, window.event.srcElement.value""> "
                    eHtml = eHtml & "<span style='font-size:10px; color:#e5c38c;'>KEY:</span><input type='text' value=""" & p(0) & """ style='width:75px; padding:1px; border:1px solid #3d4a5d; background:#050a12; color:#fff; font-size:11px;' onchange=""VBScript:InlineSave " & i & ", 0, window.event.srcElement.value""> "
                    eHtml = eHtml & "<span style='font-size:10px; color:#e5c38c;'>Win:</span>"
                    eHtml = eHtml & "<input type='text' value=""" & wW & """ style='width:28px; padding:1px; text-align:center; border:1px solid #3d4a5d; background:#050a12; color:#fff; font-size:11px;' onchange=""VBScript:InlineSave " & i & ", 3, window.event.srcElement.value"">x"
                    eHtml = eHtml & "<input type='text' value=""" & wH & """ style='width:28px; padding:1px; text-align:center; border:1px solid #3d4a5d; background:#050a12; color:#fff; font-size:11px;' onchange=""VBScript:InlineSave " & i & ", 4, window.event.srcElement.value""> "
                    eHtml = eHtml & "<span style='font-size:10px; color:#e5c38c;'>Pos:</span>"
                    eHtml = eHtml & "<input type='text' value=""" & wX & """ style='width:22px; padding:1px; text-align:center; border:1px solid #3d4a5d; background:#050a12; color:#fff; font-size:11px;' onchange=""VBScript:InlineSave " & i & ", 5, window.event.srcElement.value"">,"
                    eHtml = eHtml & "<input type='text' value=""" & wY & """ style='width:22px; padding:1px; text-align:center; border:1px solid #3d4a5d; background:#050a12; color:#fff; font-size:11px;' onchange=""VBScript:InlineSave " & i & ", 6, window.event.srcElement.value"">"
                    eHtml = eHtml & "<input type='checkbox'" & chk & " title='Применять настройки' style='vertical-align:middle; margin-left:6px; margin-right:2px;' onchange=""VBScript:InlineSaveBox " & i & ", window.event.srcElement.checked"">"
                    eHtml = eHtml & "</div></td>"
                    
                    eHtml = eHtml & "<td><button class='btn-del-row' style='width:18px;height:18px;line-height:16px;padding:0;' onclick=""VBScript:DeleteKey " & i & """>X</button></td></tr>"
                End If
            Next
            eHtml = eHtml & "</table>"


            eHtml = eHtml & "<div class='label-text'>Порядок групп:</div><table class='edit-table'><tr><th width='55'>Сорт</th><th>Имя группы</th><th width='30'>X</th></tr>"
            For i = 0 To UBound(finalOrder)
                gName = finalOrder(i)
                If Trim(gName) <> "" Then
                    eHtml = eHtml & "<tr><td><button class='btn-arr' onclick=""VBScript:MoveGroup " & i & ", -1"">^</button> <button class='btn-arr' onclick=""VBScript:MoveGroup " & i & ", 1"">v</button></td>"
                    eHtml = eHtml & "<td align='left'><span class='clickable-name' onclick=""VBScript:RenameGrp " & i & """>" & gName & "</span></td>"
                    eHtml = eHtml & "<td><button class='btn-del-row' onclick=""VBScript:DeleteGroup '" & gName & "' "">X</button></td></tr>"
                End If
            Next
            document.getElementById("edit_list").innerHTML = eHtml & "</table>"
            
            Set sel = document.getElementById("newC") : sel.options.length = 0
            For Each cN In finalOrder
                If Trim(cN) <> "" Then
                    Set opt = document.createElement("option") : opt.text = cN : opt.value = cN : sel.add(opt)
                End If
            Next
        End Sub

        Sub InlineSave(idx, fieldNum, newVal)
            Set f = fso.OpenTextFile(kFile, 1) : lines = Split(f.ReadAll, vbCrLf) : f.Close
            If idx <= UBound(lines) Then
                p = Split(lines(idx), "|")
                If UBound(p) < 7 Then
                    ReDim Preserve p(7)
                    If Trim(p(3)) = "" Then p(3) = "1024"
                    If Trim(p(4)) = "" Then p(4) = "768"
                    If Trim(p(5)) = "" Then p(5) = "0"
                    If Trim(p(6)) = "" Then p(6) = "0"
                    If Trim(p(7)) = "" Then p(7) = "1"
                End If
                p(fieldNum) = Trim(newVal)
                lines(idx) = Join(p, "|")
                Set f = fso.OpenTextFile(kFile, 2) : f.Write Join(lines, vbCrLf) : f.Close
            End If
        End Sub

        Sub InlineSaveBox(idx, isChecked)
            valBox = "0" : If isChecked Then valBox = "1"
            InlineSave idx, 7, valBox
        End Sub

        Sub LaunchGame(key, idx)
            ini = document.getElementById("pathInput").value
            If fso.FileExists(ini) Then
                Set f = fso.OpenTextFile(kFile, 1) : lines = Split(f.ReadAll, vbCrLf) : f.Close
                p = Split(lines(idx), "|")
                
                wW = "1024" : wH = "768" : wX = "0" : wY = "0" : useOpt = "1"
                If UBound(p) >= 6 Then
                    If Trim(p(3)) <> "" Then wW = Trim(p(3))
                    If Trim(p(4)) <> "" Then wH = Trim(p(4))
                    If Trim(p(5)) <> "" Then wX = Trim(p(5))
                    If Trim(p(6)) <> "" Then wY = Trim(p(6))
                End If
                If UBound(p) >= 7 Then useOpt = Trim(p(7))

                If useOpt = "1" Or useOpt = "" Then
                    gameDir = fso.GetParentFolderName(fso.GetParentFolderName(ini))
                    optionIniPath = gameDir & "\asterios\Option.ini"
                    If fso.FileExists(optionIniPath) Then
                        Set fOpt = fso.OpenTextFile(optionIniPath, 1) : optData = fOpt.ReadAll : fOpt.Close
                        Set r = New RegExp : r.Global = True
                        r.Pattern = "GamePlayViewportX=[0-9]*" : optData = r.Replace(optData, "GamePlayViewportX=" & wW)
                        r.Pattern = "GamePlayViewportY=[0-9]*" : optData = r.Replace(optData, "GamePlayViewportY=" & wH)
                        r.Pattern = "WindowPosX=[0-9\-]*"
                        If r.Test(optData) Then
                            optData = r.Replace(optData, "WindowPosX=" & wX)
                        Else
                            optData = Replace(optData, "[Video]", "[Video]" & vbCrLf & "WindowPosX=" & wX)
                        End If
                        r.Pattern = "WindowPosY=[0-9\-]*"
                        If r.Test(optData) Then
                            optData = r.Replace(optData, "WindowPosY=" & wY)
                        Else
                            optData = Replace(optData, "[Video]", "[Video]" & vbCrLf & "WindowPosY=" & wY)
                        End If
                        Set fOpt = fso.OpenTextFile(optionIniPath, 2) : fOpt.Write optData : fOpt.Close
                    End If
                End If

                Set f = fso.OpenTextFile(ini, 1) : d = f.ReadAll : f.Close
                Set r = New RegExp : r.Pattern = "Key=[A-Za-z0-9]*" : r.Global = True
                d = r.Replace(d, "Key=" & key)
                Set f = fso.OpenTextFile(ini, 2) : f.Write d : f.Close
                
                gameDir = fso.GetParentFolderName(fso.GetParentFolderName(ini))
                exe = gameDir & "\Asterios.exe"
                If fso.FileExists(exe) Then objShell.Run Chr(34) & exe & Chr(34) & " /autoplay", 1, False
            End If
        End Sub

        Sub RenameGrp(idx)
            orderArr = Split(globalGroupOrder, ",")
            If idx <= UBound(orderArr) Then
                oldName = orderArr(idx)
                If LCase(oldName) = "разное" Then Exit Sub
                newName = InputBox("Введите новое название:", "Редактор", oldName)
                If Trim(newName) <> "" And newName <> oldName Then
                    Set f = fso.OpenTextFile(kFile, 1) : txt = f.ReadAll : f.Close
                    txt = Replace(txt, "|" & oldName, "|" & newName)
                    Set f = fso.OpenTextFile(kFile, 2) : f.Write txt : f.Close
                    globalGroupOrder = Replace("," & globalGroupOrder & ",", "," & oldName & ",", "," & newName & ",")
                    If Left(globalGroupOrder, 1) = "," Then globalGroupOrder = Mid(globalGroupOrder, 2)
                    If Right(globalGroupOrder, 1) = "," Then globalGroupOrder = Left(globalGroupOrder, Len(globalGroupOrder) - 1)
                    SaveSettings : LoadData
                End If
            End If
        End Sub

        Sub RenameAcc(idx)
On Error GoTo 0
            Set f = fso.OpenTextFile(kFile, 1) : rLines = Split(f.ReadAll, vbCrLf) : f.Close
            If idx <= UBound(rLines) Then
                p = Split(rLines(idx), "|")
                globalEditIdx = idx
                wW = "1024" : wH = "768" : wX = "0" : wY = "0"
                If UBound(p) >= 6 Then
                    wW = p(3) : wH = p(4) : wX = p(5) : wY = p(6)
                End If
                  document.getElementById("modalName").value = p(1)
                document.getElementById("modalKey").value = p(0)
                document.getElementById("modalwidth").value = wW
                document.getElementById("modalheight").value = wH
                document.getElementById("modalPosX").value = wX
                document.getElementById("modalPosY").value = wY
                document.getElementById("editModal").style.display = "block"
            End If
        End Sub

        Sub SaveModalEdit
            newName = document.getElementById("modalName").value
            newKey = document.getElementById("modalKey").value
            newWidth = document.getElementById("modalwidth").value
            newHeight = document.getElementById("modalheight").value
            newPosX = document.getElementById("modalPosX").value
            newPosY = document.getElementById("modalPosY").value
            If Trim(newWidth) = "" Then newWidth = "1024"
            If Trim(newHeight) = "" Then newHeight = "768"
            If Trim(newPosX) = "" Then newPosX = "0"
            If Trim(newPosY) = "" Then newPosY = "0"
            If Trim(newName) <> "" And Trim(newKey) <> "" Then
                Set f = fso.OpenTextFile(kFile, 1) : wLines = Split(f.ReadAll, vbCrLf) : f.Close
                p = Split(wLines(globalEditIdx), "|")
                wLines(globalEditIdx) = newKey & "|" & newName & "|" & p(2) & "|" & newWidth & "|" & newHeight & "|" & newPosX & "|" & newPosY
                Set f = fso.OpenTextFile(kFile, 2) : f.Write Join(wLines, vbCrLf) : f.Close
                CloseModal
                LoadData
            Else
                MsgBox "Поля Имя и Ключ не могут быть пустыми!", 48, "Ошибка"
            End If
        End Sub

        Sub CloseModal
            document.getElementById("editModal").style.display = "none"
        End Sub

        Sub MoveGroup(idx, dir)
            orderArr = Split(globalGroupOrder, ",")
            target = idx + dir
            If target >= 0 And target <= UBound(orderArr) Then
                If orderArr(idx) = "Разное" Or orderArr(target) = "Разное" Then Exit Sub
                tmp = orderArr(idx) : orderArr(idx) = orderArr(target) : orderArr(target) = tmp
                globalGroupOrder = Join(orderArr, ",")
                SaveSettings : LoadData
            End If
        End Sub

        Sub ChangeRowGrp(idx, newVal)
            Set f = fso.OpenTextFile(kFile, 1) : lines = Split(f.ReadAll, vbCrLf) : f.Close
            p = Split(lines(idx), "|")
            lines(idx) = p(0) & "|" & p(1) & "|" & newVal
            Set f = fso.OpenTextFile(kFile, 2) : f.Write Join(lines, vbCrLf) : f.Close : LoadData
        End Sub

        Sub MoveRow(idx, dir)
            Set f = fso.OpenTextFile(kFile, 1) : lines = Split(f.ReadAll, vbCrLf) : f.Close
            t = idx + dir
            If t >= 0 And t <= UBound(lines) Then
                tmp = lines(idx) : lines(idx) = lines(t) : lines(t) = tmp
                Set f = fso.OpenTextFile(kFile, 2) : f.Write Join(lines, vbCrLf) : f.Close : LoadData
            End If
        End Sub

        Sub DeleteKey(idx)
            If MsgBox("Удалить персонажа?", 33) = 1 Then
                Set f = fso.OpenTextFile(kFile, 1) : lines = Split(f.ReadAll, vbCrLf) : f.Close
                nD = "" : For j = 0 To UBound(lines)
                    If j <> CInt(idx) And Trim(lines(j)) <> "" Then nD = nD & lines(j) & vbCrLf
                Next
                Set f = fso.OpenTextFile(kFile, 2, True) : f.Write nD : f.Close : LoadData
            End If
        End Sub

        Sub DeleteGroup(gName)
            If LCase(gName) = "разное" Then Exit Sub
            If MsgBox("Удалить группу?", 33) = 1 Then
                Set f = fso.OpenTextFile(kFile, 1) : txt = f.ReadAll : f.Close
                newTxt = Replace(txt, "|" & gName, "|Разное")
                Set f = fso.OpenTextFile(kFile, 2) : f.Write newTxt : f.Close
                globalGroupOrder = Replace("," & globalGroupOrder & ",", "," & gName & ",", ",")
                SaveSettings : LoadData
            End If
        End Sub

        Sub SaveNew()
            k = document.getElementById("newK").value : n = document.getElementById("newN").value : c = document.getElementById("newC").value
            If k <> "" And n <> "" Then
                Set f = fso.OpenTextFile(kFile, 8, True) : f.WriteLine k & "|" & n & "|" & c & "|1024|768|0|0" : f.Close
                document.getElementById("newK").value = "" : document.getElementById("newN").value = "" : LoadData
            End If
        End Sub

       Sub AddNewGroupFromInput()
            Dim newG
            newG = Trim(document.getElementById("newGroupInput").value)
            If newG <> "" Then
                If InStr("," & globalGroupOrder & ",", "," & newG & ",") = 0 Then
                    If globalGroupOrder = "" Then globalGroupOrder = newG Else globalGroupOrder = globalGroupOrder & "," & newG
                    document.getElementById("newGroupInput").value = ""
                    SaveSettings
                    LoadData
                End If
            End If
        End Sub

        Sub Browse()
            Set exec = objShell.Exec("powershell -Command ""Add-Type -AssemblyName System.Windows.Forms; $f = New-Object Windows.Forms.OpenFileDialog; $f.Filter = 'INI (*.ini)|*.ini'; $f.ShowDialog() | Out-Null; $f.FileName""")
            p = Replace(exec.StdOut.ReadAll, vbCrLf, "")
            If p <> "" Then document.getElementById("pathInput").value = p : SaveSettings : LoadData
        End Sub

        Sub document_OnKeyDown
            If window.event.keyCode = 27 Then
                window.close()
            End If
        End Sub
    </script>
</head>
<body>
<table class="tabs-table">
    <tr><td id="t1" class="tab tab-active" onclick="VBScript:ShowTab 1">АККАУНТЫ</td><td id="t3" class="tab" onclick="VBScript:ShowTab 3">РЕДАКТОР</td><td id="t2" class="tab" onclick="VBScript:ShowTab 2">НАСТРОЙКИ</td></tr>
</table>
<div id="c1" class="main-container"><div id="acc_list"></div><div class="exit-wrap"><button class="btn-exit" onclick="VBScript:window.close()">ВЫХОД</button></div></div>
<div id="c3" class="main-container" style="display:none;">
    <div class="edit-container-tab">
        <!-- Кнопка ГОТОВО теперь всегда сверху, прямо под табами -->
        <div style="padding: 10px; background: rgba(0,0,0,0.5); width: 100%; box-sizing: border-box;">
            <button class="btn-save" onclick="VBScript:ShowTab 1">ГОТОВО</button>
        </div>
        
        <!-- Скролл-бокс с таблицами персонажей теперь идет ниже кнопки -->
        <div id="edit_list" class="edit-scroll-box"></div>
    </div>
</div>
<div id="c2" class="main-container" style="display:none">
    <div class="settings-width">
        <div class="config-box">
            <div class="label-text">Путь к AsteriosGame.ini:</div>
            <input type="text" id="pathInput" class="input-path" readonly><button class="btn-save" style="padding:5px; margin-top:5px; height:30px;" onclick="VBScript:Browse">ОБЗОР</button>
            
            <div style="border-top:1px solid #3d4a5d; margin:15px 0;"></div>
            
            <!-- Блок 1. Данные нового персонажа сгруппированы вместе -->
            <table width="100%" border="0">
                <tr>
                    <td width="48%"><div class="label-text" style="margin:0;">Key:</div><input type="text" id="newK" class="input-field" placeholder="Ключ"></td>
                    <td width="4%"></td>
                    <td width="48%"><div class="label-text" style="margin:0;">Имя:</div><input type="text" id="newN" class="input-field" placeholder="Описание"></td>
                </tr>
            </table>

            <div class="label-text" style="margin-top:15px;">Выбрать группу для персонажа:</div>
            <select id="newC" style="padding:5px; width:100%;"></select>
            
            <div style="border-top:1px solid #3d4a5d; margin:15px 0;"></div>

            <!-- Блок 2. Количество столбцов (относится к общим настройкам лаунчера) -->
            <div class="label-text">Количество столбцов:</div>
            <select id="selCols" onchange="VBScript:SaveSettings : LoadData" style="width:100%; padding:5px;">
                <option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option>
                <option value="5">5</option><option value="6">6</option>
            </select>

            <div style="border-top:1px solid #3d4a5d; margin:15px 0;"></div>

            <!-- Блок 3. Создание новой группы убрано в самый низ как редкое действие -->
            <div class="label-text">Создание новой группы:</div>
            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                <tr>
                    <td><input type="text" id="newGroupInput" class="input-field" placeholder="Введите название группы" style="box-sizing:border-box;"></td>
                    <td width="35" align="right"><button class="small-btn" onclick="VBScript:AddNewGroupFromInput">+</button></td>
                </tr>
            </table>
        </div>
        <button class="btn-save" onclick="VBScript:SaveNew" style="margin-top:10px;">СОХРАНИТЬ ПЕРСОНАЖА</button><button class="btn-exit" onclick="VBScript:window.close()" style="margin-top:5px;">ВЫХОД</button>
    </div>
</div>
</body>
</html>
